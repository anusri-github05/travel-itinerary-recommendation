# =============================================================================
# Copy this file to ".env" (same folder) and fill in YOUR keys.
# Never commit the real ".env" file -- it's already in .gitignore.
# =============================================================================

# ---- Choose ONE provider: "gemini", "groq", or "openrouter" ----
LLM_PROVIDER=gemini

# --- Option A: Google AI Studio (Gemini) -- free, no card required ---
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini/gemini-2.5-flash

# --- Option B: Groq -- free, no card required, extremely fast ---
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=groq/llama-3.3-70b-versatile

# --- Option C: OpenRouter -- free ":free" models, good backup if A/B are
#     unavailable in your country ---
# Get a key: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct:free

# ---- Web search (optional) ----
# If TAVILY_API_KEY is left blank, WebSearchTool automatically falls back
# to free DuckDuckGo search -- the app still works with ZERO keys here.
# Get a free Tavily key (1,000 searches/month, no card): https://app.tavily.com
TAVILY_API_KEY=
